# ── Azure AI Foundry ─────────────────────────────────────────────
# Your Foundry project endpoint (from Foundry portal → Overview)
PROJECT_ENDPOINT=https://<your-ai-services>.services.ai.azure.com/api/projects/<project-name>

# Model deployment name (from Foundry portal → Models + endpoints)
MODEL_DEPLOYMENT_NAME=<your-model-deployment-name>

# ── Databricks Genie MCP ────────────────────────────────────────
# Databricks workspace hostname (no https://)
DATABRICKS_HOST=<your-databricks-instance>.azuredatabricks.net

# Genie Space ID
GENIE_SPACE_ID=<your-genie-space-id>

# Databricks Personal Access Token (for local dev only — production uses OAuth or Key Vault)
# DATABRICKS_TOKEN=dapi_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Databricks Authentication Mode ──────────────────────────────
# 'oauth' (default) — Entra ID token federation (passwordless, no PAT needed)
#   Requires: federation policy configured in Databricks Account Console
#   Uses DefaultAzureCredential → Entra ID token → Databricks OIDC exchange
# 'pat' — Legacy PAT mode (uses KEY_VAULT_URL or DATABRICKS_TOKEN env var)
# 'u2m' — User-to-Machine: each user signs into Databricks via OAuth PKCE
#   Requires: DATABRICKS_OAUTH_CLIENT_ID, DATABRICKS_OAUTH_CLIENT_SECRET,
#   DATABRICKS_OAUTH_REDIRECT_URI, and REDIS_URL
DATABRICKS_AUTH_MODE=oauth

# Databricks service principal client ID (required for managed identity / workload federation)
# Not needed for local dev with Azure CLI (account-wide federation handles user tokens)
# DATABRICKS_SP_CLIENT_ID=<your-service-principal-client-id>

# ── Azure Key Vault (only needed for PAT mode) ──────────────────
# KEY_VAULT_URL=<your-key-vault-url>
# KEY_VAULT_SECRET_NAME=<your-key-vault-secret-name-containing-databricks-pat>

# ── U2M OAuth (only needed when DATABRICKS_AUTH_MODE=u2m) ────────
# DATABRICKS_OAUTH_CLIENT_ID=<from Databricks Account Console>
# DATABRICKS_OAUTH_CLIENT_SECRET=<from Key Vault>
# DATABRICKS_OAUTH_REDIRECT_URI=https://<your-app>/oauth/callback
# REDIS_URL=rediss://:password@host:6380/0

# ── Teams Bot (only needed for teams_app.py) ────────────────────
MICROSOFT_APP_ID=<your-azure-bot-app-id>
MICROSOFT_APP_PASSWORD=
MICROSOFT_APP_TENANT_ID=<your-azure-ad-tenant-id>
MICROSOFT_APP_TYPE=UserAssignedMSI
PORT=3978